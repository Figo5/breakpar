# Postgres (Vercel Postgres, Neon, Supabase, etc.)
# DATABASE_URL is used at RUNTIME — point it at the POOLED connection string
# (Neon "-pooler" host / PgBouncer) so serverless functions don't exhaust
# Postgres connections under load.
DATABASE_URL="postgresql://user:pass@host-pooler:5432/break80?sslmode=require"

# DIRECT_URL is used by `prisma migrate` / `prisma db push` only — it must be a
# DIRECT (non-pooled) connection. For local dev both can be the same value.
DIRECT_URL="postgresql://user:pass@host:5432/break80?sslmode=require"

# Clerk — https://dashboard.clerk.com (optional: guests can play without it)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Server-only secret that seeds the per-hole RNG. Keep it private; rotating it
# changes future outcomes, so set once and leave it.
SERVER_SEED="change-me-to-a-long-random-string"

# Password for the admin feedback inbox (/admin/feedback). The login form
# exchanges it for a signed session cookie. Leave empty to lock the page.
ADMIN_PASSWORD="change-me"
