// Break 80 — PostgreSQL schema (Prisma)
// Maps directly to the five models in the spec, with the relations and the
// daily uniqueness constraints the gameplay needs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime uses the POOLED connection (PgBouncer/Neon pooler) so serverless
  // functions don't exhaust Postgres connections. Migrations use the DIRECT one.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  // A user is backed by EITHER a Clerk account or an anonymous guest id.
  clerkId   String?  @unique // Clerk subject, once signed in
  guestId   String?  @unique // anonymous cookie identity for zero-login play
  username  String            // display only — not unique (guests share patterns)
  email     String?  @unique  // null for guests / providers without email
  xHandle   String?           // X/Twitter handle ONLY (no @, no URL); optional
  imageUrl  String?           // Clerk profile image (imageUrl), synced on login; null = show initial
  createdAt DateTime @default(now())

  // Public profile (accounts only; guests never get one). Default PUBLIC with an
  // opt-out. featuredTrophies is an ordered list of up to 5 catalogue trophy ids
  // the owner pins to their public profile (validated earned on write).
  profilePublic    Boolean  @default(true)
  featuredTrophies String[] @default([])
  // NOTE: a PARTIAL UNIQUE INDEX on (username) WHERE clerkId IS NOT NULL is added
  // via raw SQL in the migration — it guarantees account usernames resolve
  // uniquely for /u/[username] while guests keep sharing display names. Prisma
  // can't express a filtered unique in-schema, so it lives in migration SQL.

  rounds       Round[]
  streak       Streak?
  trophyAwards TrophyAward[]

  // Challenges (accounts only). Directed: challenger -> opponent, both accounts.
  challengesSent     Challenge[] @relation("challengesSent")
  challengesReceived Challenge[] @relation("challengesReceived")

  // Social graph (accounts only; gated in the app layer). Follows are directed;
  // a "friend" is a MUTUAL follow (both directions exist). Request/accept can be
  // layered later as an additive status column without reworking these.
  following Follow[] @relation("following") // edges where this user is the follower
  followers Follow[] @relation("followers") // edges where this user is the followee
}

// A directed follow edge. Both endpoints must be accounts (enforced in
// lib/friends + routes; guests have no social graph). "Friends" = a pair of
// edges in both directions. Unique prevents double-follows; self-follows are
// rejected in code.
model Follow {
  id         String   @id @default(cuid())
  followerId String // who follows
  followeeId String // who is followed
  createdAt  DateTime @default(now())

  follower User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("followers", fields: [followeeId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId])
}

model Course {
  id         String  @id @default(cuid())
  slug       String  @unique
  name       String
  location   String
  rating     Float
  slope      Int
  difficulty Int     // 1..10
  wind       Int
  greens     String

  holes      Hole[]
  rounds     Round[]
  challenges Challenge[]
}

model Hole {
  id          String @id @default(cuid())
  courseId    String
  holeNumber  Int    // 1..18
  par         Int
  yardage     Int
  strokeIndex Int    // 1 = hardest

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, holeNumber])
}

model Round {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  mode        String   @default("daily") // "daily" (ranked) | "unlimited" (practice) | "challenge" (head-to-head)
  dateKey     String?  // "2026-06-25" for daily rounds; null for unlimited/challenge play
  // Shared RNG namespace for challenge rounds (= Challenge.seedKey) so both
  // players face identical hole conditions. null for daily/unlimited -> the hole
  // route seeds from round.id as before (byte-identical, calibration untouched).
  seedKey     String?
  score       Int      @default(0)
  relativeToPar Int    @default(0)
  completed   Boolean  @default(false)
  durationMs  Int?
  playedAt    DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id])
  holeResults HoleResult[]

  // Back-relations for a challenge's per-side round links (each @unique on
  // Challenge, so a round is at most one side of one challenge).
  challengerFor Challenge? @relation("challengerRound")
  opponentFor   Challenge? @relation("opponentRound")

  // one ranked round per player per day. Unlimited rounds use dateKey = null,
  // and Postgres treats each NULL as distinct, so a player can have many.
  @@unique([userId, dateKey])
  @@index([dateKey, score])
  @@index([userId, mode])
}

// A head-to-head challenge: two accounts play the SAME course from a shared
// seedKey (= this challenge's id), then compare to-par. Async — each plays on
// their own time; settled when both rounds complete. Challenge rounds are a
// separate mode: outside the daily rotation, streak, leaderboard, trophies and
// HoF (excluded via a mode guard) so a chosen seed can't farm records.
model Challenge {
  id                String    @id @default(cuid())
  challengerId      String
  opponentId        String
  courseId          String
  seedKey           String // shared RNG namespace (set = id on create)
  status            String    @default("pending") // pending|active|complete|declined|expired
  challengerRoundId String?   @unique // one attempt per side (DB-enforced)
  opponentRoundId   String?   @unique
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  challenger      User   @relation("challengesSent", fields: [challengerId], references: [id], onDelete: Cascade)
  opponent        User   @relation("challengesReceived", fields: [opponentId], references: [id], onDelete: Cascade)
  course          Course @relation(fields: [courseId], references: [id])
  challengerRound Round? @relation("challengerRound", fields: [challengerRoundId], references: [id])
  opponentRound   Round? @relation("opponentRound", fields: [opponentRoundId], references: [id])

  @@index([opponentId, status])
  @@index([challengerId, status])
}

model HoleResult {
  id          String @id @default(cuid())
  roundId     String
  holeNumber  Int
  decision    String // "safe" | "normal" | "aggressive"
  outcome     String // "eagle" | "birdie" | ...
  scoreChange Int

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  // a hole can only be played once per round (anti re-roll)
  @@unique([roundId, holeNumber])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?  // null for fully anonymous senders
  kind      String   @default("general") // "bug" | "course" | "general"
  message   String
  email     String?  // optional reply-to the sender chose to share
  path      String?  // page the widget was opened from
  resolved  Boolean  @default(false) // triaged/handled flag for the admin inbox
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@index([resolved, createdAt])
}

// A trophy awarded to a user, recorded once (idempotent via the unique). B1
// derives the trophy set live; this table only persists WHEN each was first
// unlocked, so the result screen can celebrate genuinely-new unlocks.
// unlockedAt is NULLABLE on purpose: rows backfilled for trophies earned BEFORE
// B2 shipped have no real date (null), while trophies unlocked by an actual
// round get a real timestamp. So the UI shows a date only when it's truthful.
model TrophyAward {
  id         String    @id @default(cuid())
  userId     String
  trophyId   String    // matches the lib/trophies catalogue id (e.g. "first-eagle")
  unlockedAt DateTime? // real time for a genuine unlock; null = backfilled (unknown)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, trophyId]) // a trophy is awarded once, ever
  @@index([userId])
}

model Streak {
  id                 String @id @default(cuid())
  userId             String @unique
  daysPlayed         Int    @default(0)
  currentStreak      Int    @default(0)
  maxStreak          Int    @default(0) // longest day-streak ever (survives a miss)
  underParStreak     Int    @default(0) // consecutive under-par days
  underParTotal      Int    @default(0) // total under-par days (for win %)
  bestScore          Int    @default(999) // best relative-to-par score
  lastPlayedKey      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
